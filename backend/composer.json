{
    "name": "hansmed/backend",
    "description": "HansMed TCM Platform Backend",
    "type": "project",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "laravel/octane": "^2.5",
        "laravel/sanctum": "^4.0",
        "laravel/socialite": "^5.13",
        "resend/resend-laravel": "^0.16",
        "aws/aws-sdk-php": "^3.300",
        "league/flysystem-aws-s3-v3": "^3.0",
        "predis/predis": "^2.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@php artisan package:discover --ansi"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
