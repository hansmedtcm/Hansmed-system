APP_NAME=HansMed
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=hansmed
DB_USERNAME=hansmed
DB_PASSWORD=hansmed

QUEUE_CONNECTION=database
CACHE_STORE=database
SESSION_DRIVER=database
REDIS_HOST=redis

FILESYSTEM_DISK=public

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# --- Payments safety switch ---
# Keep PAYMENTS_PILOT_MODE=true until the pilot-readiness checklist is
# fully signed off. When true, all payment calls are stubbed — no real
# money can move, even if a real STRIPE_SECRET is configured. See
# config/payments.php and docs/pilot-readiness-checklist.md.
PAYMENTS_PILOT_MODE=true

# --- External services (leave empty in dev to use stubs) ---
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

AGORA_APP_ID=
AGORA_APP_CERT=

TONGUE_API_URL=
TONGUE_API_KEY=

# --- Cloudflare R2 (Brief 1A — tongue-image storage) ---
# All five must be set for the 'r2' disk to work. Real values live on
# Railway, never commit them. R2_REGION is always literal 'auto' — R2
# has no region concept but the S3 SDK requires the field be present.
# R2_ENDPOINT format: https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_REGION=auto
