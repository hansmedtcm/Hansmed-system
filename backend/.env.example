APP_NAME=HansMed
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=hansmed
DB_USERNAME=hansmed
DB_PASSWORD=hansmed

QUEUE_CONNECTION=database
CACHE_STORE=database
SESSION_DRIVER=database
REDIS_HOST=redis

FILESYSTEM_DISK=public

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# --- Payments safety switch ---
# Keep PAYMENTS_PILOT_MODE=true until the pilot-readiness checklist is
# fully signed off. When true, all payment calls are stubbed — no real
# money can move, even if a real STRIPE_SECRET is configured. See
# config/payments.php and docs/pilot-readiness-checklist.md.
PAYMENTS_PILOT_MODE=true

# --- External services (leave empty in dev to use stubs) ---
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

AGORA_APP_ID=
AGORA_APP_CERT=

TONGUE_API_URL=
TONGUE_API_KEY=
