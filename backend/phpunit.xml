<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         processIsolation="false"
         stopOnFailure="false"
         executionOrder="random"
         failOnWarning="true"
         failOnRisky="true"
         failOnEmptyTestSuite="true"
         beStrictAboutOutputDuringTests="true"
         cacheDirectory=".phpunit.cache">
    <testsuites>
        <!--
            2026-05-18 — Removed the empty "Unit" testsuite block. The
            tests/Unit directory was never created, and PHPUnit 11.5 with
            failOnEmptyTestSuite="true" hard-errors at startup with
            "Test directory ... not found", which is what kept CI #10-#14
            red despite the actual feature tests being fine. Re-add this
            block (and create backend/tests/Unit/SomethingTest.php first)
            when there's an actual unit test to host.
        -->
        <testsuite name="Feature">
            <directory suffix="Test.php">./tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory suffix=".php">./app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_KEY" value="base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="CACHE_STORE" value="array"/>
        <!--
            Test DB is real MySQL loaded from backend/database/schema.sql.
            In CI this points at the mysql:8.0 service container declared
            in .github/workflows/ci.yml. Locally, run `docker run -d
            -p 3306:3306 -e MYSQL_ROOT_PASSWORD=testroot
            -e MYSQL_DATABASE=hansmed_test mysql:8.0` and then
            `mysql -h127.0.0.1 -uroot -ptestroot hansmed_test < database/schema.sql`
            before running PHPUnit. RefreshDatabase is NOT used (would
            re-run only the 5 Laravel migrations, leaving the ~25
            schema.sql tables missing); tests use DatabaseTransactions
            instead — see backend/tests/TestCase.php.
        -->
        <env name="DB_CONNECTION" value="mysql"/>
        <env name="DB_HOST" value="127.0.0.1"/>
        <env name="DB_PORT" value="3306"/>
        <env name="DB_DATABASE" value="hansmed_test"/>
        <env name="DB_USERNAME" value="root"/>
        <env name="DB_PASSWORD" value="testroot"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <!--
            Force Sanctum out of stateful mode in tests. Without this,
            Sanctum treats the default Laravel test domain 'localhost'
            as stateful (it's in the default SANCTUM_STATEFUL_DOMAINS
            list), which causes session-cookie bleed between requests
            inside one test method. That bug was CI #18 — the doctor's
            session cookie made the next Bearer-authed patient request
            resolve as the doctor and 403 on role:patient. Empty value
            here means "no stateful domains" — Sanctum falls through
            to pure Bearer-header token auth, which is what the tests
            (and the prod browser flow with cross-origin tokens) use.
        -->
        <env name="SANCTUM_STATEFUL_DOMAINS" value=""/>
    </php>
</phpunit>
